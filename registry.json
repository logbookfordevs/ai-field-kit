{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "ai-field-kit",
  "homepage": "https://github.com/logbookfordevs/ai-field-kit",
  "items": [
    {
      "name": "afk-catalog",
      "type": "registry:item",
      "title": "AFK Catalog",
      "description": "Project-local AFK setup catalog for rules, skills, profiles, Custom Agents, MCPs, plugins, hooks, and presets.",
      "files": [
        {
          "path": "packages/afk/catalog/skills.json",
          "type": "registry:file",
          "target": "~/afk/catalog/skills.json"
        },
        {
          "path": "packages/afk/catalog/profiles.json",
          "type": "registry:file",
          "target": "~/afk/catalog/profiles.json"
        },
        {
          "path": "packages/afk/catalog/agents.json",
          "type": "registry:file",
          "target": "~/afk/catalog/agents.json"
        },
        {
          "path": "packages/afk/catalog/mcps.json",
          "type": "registry:file",
          "target": "~/afk/catalog/mcps.json"
        },
        {
          "path": "packages/afk/catalog/rules.json",
          "type": "registry:file",
          "target": "~/afk/catalog/rules.json"
        },
        {
          "path": "packages/afk/catalog/plugins.json",
          "type": "registry:file",
          "target": "~/afk/catalog/plugins.json"
        },
        {
          "path": "packages/afk/catalog/hooks.json",
          "type": "registry:file",
          "target": "~/afk/catalog/hooks.json"
        },
        {
          "path": "packages/afk/catalog/presets.json",
          "type": "registry:file",
          "target": "~/afk/catalog/presets.json"
        }
      ]
    }
  ]
}
