{
    "version": 1,
    "items": [
        {
            "id": "plannotator",
            "label": "Plannotator",
            "description": "Review and annotate plans before implementation, so agents get clearer feedback loops instead of vague handoff notes.",
            "install": {
                "command": "bash",
                "args": [
                    "-c",
                    "curl -fsSL https://plannotator.ai/install.sh | bash -s -- --no-extras --model-invocable none"
                ]
            },
            "default": true
        },
        {
            "id": "goalbuddy",
            "label": "GoalBuddy",
            "description": "Install GoalBuddy's goal board, PM loop, receipts, and live local board surface for AFK Turbo.",
            "install": {
                "command": "npx",
                "args": [
                    "--yes",
                    "goalbuddy",
                    "&&",
                    "npx",
                    "--yes",
                    "goalbuddy",
                    "update"
                ]
            },
            "default": true
        },
        {
            "id": "plannotator-tot",
            "label": "Plannotator Tot",
            "description": "Install Tot's git-backed Markdown and HTML publishing CLI for living tot.page URLs with immutable snapshots.",
            "install": {
                "command": "npm",
                "args": [
                    "install",
                    "-g",
                    "@plannotator/tot"
                ]
            },
            "default": false
        },
        {
            "id": "yggtree",
            "label": "Yggtree",
            "description": "Create and manage git worktrees with a focused CLI workflow for agent-friendly branch and workspace handling.",
            "install": {
                "command": "npm",
                "args": [
                    "install",
                    "-g",
                    "yggtree"
                ]
            },
            "default": true
        },
        {
            "id": "impeccable",
            "label": "Impeccable",
            "description": "Install Impeccable's frontend design skills and design hook globally through its official installer.",
            "install": {
                "command": "sh",
                "args": [
                    "-c",
                    "cd \"$HOME\" && npx --yes impeccable install --global --force -y"
                ]
            },
            "default": false
        }
    ]
}
