{
  "name": "@logbook/afk",
  "version": "0.5.2",
  "description": "AI Field Kit setup router CLI.",
  "type": "module",
  "bin": {
    "afk": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && tsc",
    "typecheck": "npx tsc --noEmit",
    "prepack": "pnpm run build",
    "release:bump": "node ../../scripts/bump-afk-version.mjs",
    "release:bump:patch": "node ../../scripts/bump-afk-version.mjs patch",
    "release:bump:minor": "node ../../scripts/bump-afk-version.mjs minor",
    "release:bump:major": "node ../../scripts/bump-afk-version.mjs major",
    "release:pack": "../../scripts/package-afk-release.sh",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/core": "^10.3.2",
    "@inquirer/prompts": "^7.8.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7"
  }
}
