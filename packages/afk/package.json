{
  "name": "@logbookfordevs/afk",
  "version": "0.5.4",
  "description": "AI Field Kit setup router CLI.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/logbookfordevs/ai-field-kit.git",
    "directory": "packages/afk"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "afk": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "!dist/**/*.test.js"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && tsc",
    "typecheck": "npx tsc --noEmit",
    "prepack": "pnpm run build",
    "release:pack": "../../scripts/package-afk-release.sh",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7"
  }
}
